# Copy to .env.local for local development. Never commit secrets.

# Supabase (optional auth features)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Jamendo (optional free-music provider)
EXPO_PUBLIC_JAMENDO_CLIENT_ID=

# EAS / Expo build profile (set automatically on EAS builds)
EXPO_PUBLIC_BUILD_PROFILE=
