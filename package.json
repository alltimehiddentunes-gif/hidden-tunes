{
    "name":  "hidden-tunes-app",
    "main":  "index.js",
    "version":  "1.0.0",
    "scripts":  {
                    "start":  "node --max-old-space-size=4096 ./node_modules/expo/bin/cli start --max-workers 1",
                    "start:clear":  "node --max-old-space-size=4096 ./node_modules/expo/bin/cli start --clear --max-workers 1",
                    "start:expo":  "expo start",
                    "verify:tunnel-deps":  "node ./scripts/verify-dev-tunnel-deps.js",
                    "verify:preview-config":  "node ./scripts/verify-preview-config.js",
                    "start:tunnel":  "node ./scripts/start-expo-tunnel.js",
                    "start:tunnel:clear":  "node ./scripts/start-expo-tunnel.js --clear",
                    "start:dev-client":  "node ./scripts/start-expo-tunnel.js --dev-client",
                    "start:dev-client:tunnel":  "node ./scripts/start-expo-tunnel.js --dev-client",
                    "start:dev-client:clear":  "node ./scripts/start-expo-tunnel.js --dev-client --clear",
                    "start:dev-client:lan":  "npx expo start --dev-client --host lan --max-workers 1",
                    "start:dev-client:localhost":  "npx expo start --dev-client --host localhost --max-workers 1",
                    "build:preview:android":  "eas build --profile preview --platform android",
                    "build:preview:ios":  "eas build --profile preview --platform ios",
                    "build:dev-client:android":  "eas build --profile developmentClient --platform android",
                    "build:dev-client:ios":  "eas build --profile developmentClient --platform ios",
                    "reset-project":  "node ./scripts/reset-project.js",
                    "android":  "expo run:android",
                    "ios":  "expo run:ios",
                    "web":  "node --max-old-space-size=4096 ./node_modules/expo/bin/cli start --web --max-workers 1",
                    "lint":  "expo lint"
                },
    "dependencies":  {
                         "@expo/config":  "~56.0.9",
                         "@expo/vector-icons":  "^15.0.3",
                         "@react-native-async-storage/async-storage":  "2.2.0",
                         "@react-native-community/slider":  "5.2.0",
                         "@react-navigation/native":  "^7.2.5",
                         "@supabase/supabase-js":  "^2.105.4",
                         "expo":  "~56.0.8",
                         "expo-blur":  "~56.0.3",
                         "expo-clipboard":  "~56.0.3",
                         "expo-constants":  "~56.0.16",
                         "expo-dev-client":  "~56.0.18",
                         "expo-document-picker":  "~56.0.4",
                         "expo-file-system":  "~56.0.7",
                         "expo-font":  "~56.0.5",
                         "expo-haptics":  "~56.0.3",
                         "expo-image":  "~56.0.9",
                         "expo-linear-gradient":  "~56.0.4",
                         "expo-linking":  "~56.0.13",
                         "expo-media-control":  "~1.0.12",
                         "expo-router":  "~56.2.8",
                         "expo-splash-screen":  "~56.0.10",
                         "expo-status-bar":  "~56.0.4",
                         "expo-symbols":  "~56.0.5",
                         "expo-system-ui":  "~56.0.5",
                         "expo-web-browser":  "~56.0.5",
                         "react":  "19.2.3",
                         "react-dom":  "19.2.3",
                         "react-native":  "0.85.3",
                         "react-native-draggable-flatlist":  "^4.0.3",
                         "react-native-gesture-handler":  "~2.31.1",
                         "react-native-reanimated":  "4.3.1",
                         "react-native-safe-area-context":  "~5.7.0",
                         "react-native-screens":  "4.25.2",
                         "react-native-url-polyfill":  "^3.0.0",
                         "react-native-web":  "~0.21.0",
                         "react-native-webview":  "13.16.1",
                         "react-native-worklets":  "0.8.3",
                         "react-native-youtube-iframe":  "^2.4.1"
                     },
    "devDependencies":  {
                            "@expo/ngrok":  "^4.1.3",
                            "@types/react":  "~19.2.14",
                            "eslint":  "^9.25.0",
                            "eslint-config-expo":  "~56.0.4",
                            "typescript":  "~6.0.3"
                        },
    "private":  true,
    "expo":  {
                 "doctor":  {
                                "reactNativeDirectoryCheck":  {
                                                                  "exclude":  [
                                                                                  "expo-modules-jsi"
                                                                              ],
                                                                  "listUnknownPackages":  false
                                                              }
                            }
             }
}
