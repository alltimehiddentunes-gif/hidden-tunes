{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "developmentClient": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_BUILD_PROFILE": "developmentClient"
      }
    },
    "preview": {
      "developmentClient": false,
      "autoIncrement": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_BUILD_PROFILE": "preview",
        "EXPO_PUBLIC_SPORTS_ENABLED": "false",
        "EXPO_PUBLIC_SPORTS_MOBILE_PILOT_ENABLED": "false",
        "EXPO_PUBLIC_SPORTS_FULL_UI_ENABLED": "false",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "true",
        "SHARP_FORCE_PREBUILT": "true"
      }
    },
    "production": {
      "developmentClient": false,
      "autoIncrement": true,
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_BUILD_PROFILE": "production",
        "EXPO_PUBLIC_SPORTS_ENABLED": "true",
        "EXPO_PUBLIC_SPORTS_MOBILE_PILOT_ENABLED": "true",
        "EXPO_PUBLIC_SPORTS_FULL_UI_ENABLED": "true",
        "EXPO_PUBLIC_SPORTS_USE_DEV_FIXTURES": "false",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "true",
        "SHARP_FORCE_PREBUILT": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6773324462"
      }
    }
  }
}