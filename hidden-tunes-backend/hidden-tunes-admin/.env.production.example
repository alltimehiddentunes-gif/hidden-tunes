# Hidden Tunes Admin production environment
# Copy this to .env.production on the VPS and replace every placeholder.
# Do not commit .env.production or any real secrets.

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://admin.hiddentunes.com

# Public Supabase browser/auth config
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase admin access
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cloudflare R2 server upload/signing config
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_BASE_URL=https://your-r2-public-domain-or-bucket-url

# Optional ffmpeg worker proxy (server-side only; never expose secret to browser)
# AUDIO_WORKER_URL=https://hidden-tunes-audio-worker.onrender.com
# AUDIO_WORKER_SECRET=your-shared-worker-secret

# Radio HTTPS relay for catalog HTTP-only streams (HMAC signing; server-only)
# RADIO_STREAM_RELAY_SECRET=generate-a-long-random-secret
# RADIO_RELAY_PUBLIC_BASE_URL=https://admin.hiddentunes.com
